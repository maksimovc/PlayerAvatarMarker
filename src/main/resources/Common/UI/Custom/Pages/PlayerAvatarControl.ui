$C = "../Common.ui";

SceneBlur {}

Group {
  Background: #000000(0.34);
}

Group {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  LayoutMode: Center;

  Group {
    Anchor: (Width: 1280, Height: 780);

    Group #TopBar {
      Anchor: (Left: 24, Top: 18, Right: 24, Height: 66);
      Background: PatchStyle(TexturePath: "ObjectivePanelContainer.png", Border: 15);

      Label #Title {
        Anchor: (Left: 18, Top: 18, Width: 430, Height: 30);
        Style: (FontSize: 20, TextColor: #e0c27a, RenderBold: true, VerticalAlignment: Center);
        Text: "Player Avatar Control";
      }

      Button #RefreshButton {
        Anchor: (Top: 14, Right: 152, Width: 120, Height: 38);
        Background: #343850;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #RefreshButtonLabel {
          Anchor: (Full: 0);
          Text: "Refresh";
          Style: (FontSize: 14, TextColor: #f1f7fa, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      Button #CloseButton {
        Anchor: (Top: 14, Right: 24, Width: 112, Height: 38);
        Background: #314c59;
        OutlineColor: #85b6c5;
        OutlineSize: 1;
        Label #CloseButtonLabel {
          Anchor: (Full: 0);
          Text: "Close";
          Style: (FontSize: 14, TextColor: #f3f8fb, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }
    }

    Group #Sidebar {
      Anchor: (Left: 24, Top: 110, Width: 266, Bottom: 24);
      Background: PatchStyle(TexturePath: "ObjectivePanelContainer.png", Border: 15);

      Label {
        Anchor: (Left: 16, Top: 16, Right: 16, Height: 13);
        Style: (FontSize: 10, TextColor: #cdbb8d, RenderBold: true, LetterSpacing: 1);
        Text: "VISIBILITY STATUS";
      }

      Group #MapStatusBox {
        Anchor: (Left: 12, Top: 37, Right: 12, Height: 56);
        Background: #192131;
        OutlineColor: #505f78;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #MapStatusDot {
          Anchor: (Left: 0, Top: 6, Width: 10, Height: 10);
          Background: #246a49;
        }

        Label #MapStatusLabel {
          Anchor: (Left: 18, Top: 0, Right: 0, Height: 20);
          Style: (FontSize: 13, TextColor: #e6ebf4, RenderBold: true, VerticalAlignment: Center);
          Text: "Map";
        }

        Label #MapStatusCount {
          Anchor: (Left: 18, Top: 24, Right: 0, Height: 14);
          Style: (FontSize: 11, TextColor: #8f96ab, VerticalAlignment: Center);
          Text: "0/0 on";
        }
      }

      Group #MinimapStatusBox {
        Anchor: (Left: 12, Top: 101, Right: 12, Height: 56);
        Background: #192131;
        OutlineColor: #505f78;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #MinimapStatusDot {
          Anchor: (Left: 0, Top: 6, Width: 10, Height: 10);
          Background: #246a49;
        }

        Label #MinimapStatusLabel {
          Anchor: (Left: 18, Top: 0, Right: 0, Height: 20);
          Style: (FontSize: 13, TextColor: #e6ebf4, RenderBold: true, VerticalAlignment: Center);
          Text: "Minimap";
        }

        Label #MinimapStatusCount {
          Anchor: (Left: 18, Top: 24, Right: 0, Height: 14);
          Style: (FontSize: 11, TextColor: #8f96ab, VerticalAlignment: Center);
          Text: "0/0 on";
        }
      }

      Group #CompassStatusBox {
        Anchor: (Left: 12, Top: 165, Right: 12, Height: 56);
        Background: #192131;
        OutlineColor: #505f78;
        OutlineSize: 1;
        Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);

        Group #CompassStatusDot {
          Anchor: (Left: 0, Top: 6, Width: 10, Height: 10);
          Background: #246a49;
        }

        Label #CompassStatusLabel {
          Anchor: (Left: 18, Top: 0, Right: 0, Height: 20);
          Style: (FontSize: 13, TextColor: #e6ebf4, RenderBold: true, VerticalAlignment: Center);
          Text: "Compass";
        }

        Label #CompassStatusCount {
          Anchor: (Left: 18, Top: 24, Right: 0, Height: 14);
          Style: (FontSize: 11, TextColor: #8f96ab, VerticalAlignment: Center);
          Text: "0/0 on";
        }
      }

      Group {
        Anchor: (Left: 12, Top: 233, Right: 12, Height: 1);
        Background: #4e5a6f;
      }

      Label {
        Anchor: (Left: 16, Top: 248, Right: 16, Height: 13);
        Style: (FontSize: 10, TextColor: #cdbb8d, RenderBold: true, LetterSpacing: 1);
        Text: "SURFACE DEFAULTS";
      }

      Button #MapBulkButton {
        Anchor: (Left: 12, Top: 270, Right: 12, Height: 48);
        Background: #66582e;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #MapBulkButtonLabel {
          Anchor: (Full: 0);
          Text: "Map";
          Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      Button #MinimapBulkButton {
        Anchor: (Left: 12, Top: 326, Right: 12, Height: 48);
        Background: #66582e;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #MinimapBulkButtonLabel {
          Anchor: (Full: 0);
          Text: "Minimap";
          Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      Button #CompassBulkButton {
        Anchor: (Left: 12, Top: 382, Right: 12, Height: 48);
        Background: #66582e;
        OutlineColor: #c7b37b;
        OutlineSize: 1;
        Label #CompassBulkButtonLabel {
          Anchor: (Full: 0);
          Text: "Compass";
          Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }
    }

    Group #MainPanel {
      Anchor: (Left: 316, Top: 110, Right: 24, Bottom: 24);
      Background: PatchStyle(TexturePath: "ObjectivePanelContainer.png", Border: 15);

      Label #PlayersTitle {
        Anchor: (Left: 18, Top: 16, Width: 260, Height: 18);
        Text: "Online Players";
        Style: (FontSize: 15, TextColor: #e7c980, RenderBold: true);
      }

      Label #PlayersCount {
        Anchor: (Top: 16, Right: 18, Width: 240, Height: 18);
        Text: "0 players online";
        Style: (FontSize: 12, TextColor: #9dc4d0, RenderBold: true, HorizontalAlignment: End);
      }

      Group #HeaderRow {
        Anchor: (Left: 12, Top: 44, Right: 12, Height: 44);
        Visible: true;

        Label #PageIndicator {
          Anchor: (Left: 16, Top: 12, Right: 244, Height: 18);
          Style: (FontSize: 13, TextColor: #e7edf7, RenderBold: true, VerticalAlignment: Center);
          Text: "Page 1/1";
        }

        Button #PrevPageButton {
          Anchor: (Top: 6, Right: 120, Width: 104, Height: 32);
          Background: #343850;
          OutlineColor: #c7b37b;
          OutlineSize: 1;
          Label #PrevPageButtonLabel {
            Anchor: (Full: 0);
            Text: "Previous";
            Style: (FontSize: 13, TextColor: #f1f7fa, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          }
        }

        Button #NextPageButton {
          Anchor: (Top: 6, Right: 8, Width: 104, Height: 32);
          Background: #343850;
          OutlineColor: #c7b37b;
          OutlineSize: 1;
          Label #NextPageButtonLabel {
            Anchor: (Full: 0);
            Text: "Next";
            Style: (FontSize: 13, TextColor: #f1f7fa, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          }
        }
      }

      Group #RowsCard {
        Anchor: (Left: 12, Top: 96, Right: 12, Bottom: 12);
        Padding: (Top: 10, Bottom: 10, Left: 10, Right: 10);

        Group #RowsScroll {
          Anchor: (Full: 0);
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          Group #RowGroup {
            LayoutMode: Top;
          }
        }

        Label #EmptyState {
          Anchor: (Top: 22, Left: 16, Right: 16, Height: 22);
          Style: (FontSize: 13, TextColor: #8f96ab, HorizontalAlignment: Center);
          Text: "No players are currently online.";
          Visible: false;
        }
      }
    }
  }
}